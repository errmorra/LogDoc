# ══════════════════════════════════════════════════════════════════════════
#  AI Log Triage — Environment Variables
#  Copy this file to .env and fill in your values.
#  The tool works fully offline without any API keys (rule-based fallback).
# ══════════════════════════════════════════════════════════════════════════

# ── Threat Intelligence APIs (optional) ───────────────────────────────────
# https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# https://developers.virustotal.com/reference/overview
VIRUSTOTAL_API_KEY=

# ── LLM Backend (optional, choose one) ────────────────────────────────────

# Option A: Anthropic Claude API
# https://www.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option B: Local Ollama (run: ollama pull mistral)
# https://ollama.com
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
